# LLM 配置 (OpenAI 兼容接口)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding 配置 (OpenAI 兼容接口)
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_KEY=your_embedding_api_key_here

# 示例：使用 SiliconFlow 作为 LLM + Embedding 供应商
# OPENAI_API_KEY=sf-xxxxxxxx
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_KEY=sf-xxxxxxxx

# 示例：使用 OpenAI 原生 Embedding
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
